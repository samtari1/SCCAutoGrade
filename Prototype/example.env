# AutoGrade configuration template
# Copy values into .env and adjust as needed.

# Provider selection: openai | custom | ollama | local
MODEL_PROVIDER=custom

# Model name for the selected provider
# OpenAI example: gpt-5.4
# Custom/Ollama example: gemma3:12b
MODEL_NAME=gemma3:12b

# Custom endpoint base URL (used when MODEL_PROVIDER is custom/ollama/local)
CUSTOM_ENDPOINT=http://localhost:11434

# OpenAI API key (required when MODEL_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Optional OpenAI request tuning
OPENAI_TIMEOUT_SECONDS=240
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_BACKOFF_SECONDS=2.0

# Include .Designer.cs during grading analysis to validate WinForms event hookups
INCLUDE_DESIGNER_FOR_GRADING=true

# Hide generated sections (Designer, .g.cs, generated code) in reports for readability
HIDE_GENERATED_IN_REPORTS=true

# Focus HTML code view around likely issue lines for easier professor review
REPORT_FOCUS_ON_ISSUES=true

# Optional: grade only one student by partial name match
# Leave blank to grade all
SINGLE_STUDENT=

OPENAI_STREAM=true